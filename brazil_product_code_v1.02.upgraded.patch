-def filter_rows(rows, column, expression):
-    result = []
-    for row in rows:
-        if match_expression(row.get(column), expression):
-            result.append(row)
-    return result
+def filter_rows(rows, column, expression):
+    result = []
+    for row in rows or []:
+        if is_summary_row(row):
+            continue
+        value = row.get(column) if isinstance(row, dict) else None
+        if match_expression(value, expression):
+            result.append(row)
+    return result
@@
