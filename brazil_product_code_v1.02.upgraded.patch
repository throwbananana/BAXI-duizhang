-    rows = [row for row in rows if not is_summary_item(row)]
-    rows.append(calculate_summary(rows, columns))
-    return rows
+def refresh_summary(rows, columns):
+    return append_or_replace_summary_row(rows, columns)
+
+def format_summary_value(value):
+    if isinstance(value, Decimal):
+        if value == value.quantize(Decimal("1")):
+            return int(value)
+        return float(value)
+    return value
+
+def finalize_rows_for_display(rows):
+    final_rows = []
+    for row in rows or []:
+        if isinstance(row, dict):
+            final_rows.append({k: format_summary_value(v) for k, v in row.items()})
+        else:
+            final_rows.append(row)
+    return final_rows
+
+# Backward-compatible aliases
+is_summary_row_item = is_summary_row
+rebuild_summary_row = refresh_summary
+
