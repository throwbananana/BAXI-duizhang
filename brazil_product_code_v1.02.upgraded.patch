+import re
+from decimal import Decimal, InvalidOperation
+
+SUMMARY_ROW_ROLE = "summary"
+
+DEFAULT_COLUMN_AGGREGATION = {
+    "default": "sum",
+    "id": "none",
+    "code": "none",
+    "sku": "none",
+    "name": "none",
+    "description": "none",
+    "price": "avg",
+    "unit_price": "avg",
+    "qty": "sum",
+    "quantity": "sum",
+    "amount": "sum",
+    "total": "sum",
+}
+
+def _row_meta(row):
+    if isinstance(row, dict):
+        meta = row.get("_meta")
+        if isinstance(meta, dict):
+            return meta
+    return {}
+
+def is_summary_row(row):
+    if not isinstance(row, dict):
+        return False
+    meta = _row_meta(row)
+    if meta.get("row_role") == SUMMARY_ROW_ROLE:
+        return True
+    if row.get("__row_role__") == SUMMARY_ROW_ROLE:
+        return True
+    if row.get("is_summary") is True:
+        return True
+    return False
+
+def mark_summary_row(row, scope="filtered", source="generated"):
+    if not isinstance(row, dict):
+        row = {"value": row}
+    row = dict(row)
+    meta = dict(_row_meta(row))
+    meta["row_role"] = SUMMARY_ROW_ROLE
+    meta["summary_scope"] = scope
+    meta["summary_source"] = source
+    row["_meta"] = meta
+    row["__row_role__"] = SUMMARY_ROW_ROLE
+    row["is_summary"] = True
+    return row
+
+def iter_detail_rows(rows):
+    for row in rows or []:
+        if not is_summary_row(row):
+            yield row
+
+def _normalize_numeric_text(value):
+    if value is None:
+        return None, False
+    if isinstance(value, bool):
+        return None, False
+    if isinstance(value, (int, float, Decimal)):
+        return str(value), False
+
+    text = str(value).strip()
+    if not text:
+        return None, False
+
+    text = text.replace("\u00A0", "").replace(" ", "")
+    text = text.replace("R$", "").replace("$", "")
+
+    percent = False
+    if text.endswith("%"):
+        percent = True
+        text = text[:-1]
+
+    negative = False
+    if text.startswith("(") and text.endswith(")"):
+        negative = True
+        text = text[1:-1]
+    if text.startswith("-"):
+        negative = True
+        text = text[1:]
+
+    if "," in text and "." in text:
+        if text.rfind(",") > text.rfind("."):
+            text = text.replace(".", "").replace(",", ".")
+        else:
+            text = text.replace(",", "")
+    elif "," in text:
+        parts = text.split(",")
+        if len(parts) == 2 and len(parts[1]) in (1, 2):
+            text = text.replace(".", "").replace(",", ".")
+        else:
+            text = text.replace(",", "")
+    else:
+        text = text.replace(",", "")
+
+    text = re.sub(r"[^0-9.]+", "", text)
+    if not text:
+        return None, False
+
+    if negative:
+        text = "-" + text
+    return text, percent
+
+def parse_numeric_value(value):
+    normalized, is_percent = _normalize_numeric_text(value)
+    if normalized is None:
+        return None
+    try:
+        number = Decimal(normalized)
+    except InvalidOperation:
+        return None
+    if is_percent:
+        number = number / Decimal("100")
+    return number
+
+def try_float(value):
+    parsed = parse_numeric_value(value)
+    return float(parsed) if parsed is not None else None
+
+def _normalize_column_key(column_name):
+    if column_name is None:
+        return ""
+    return str(column_name).strip().lower()
+
+def get_column_aggregation(column_name):
+    key = _normalize_column_key(column_name)
+    return DEFAULT_COLUMN_AGGREGATION.get(key, DEFAULT_COLUMN_AGGREGATION["default"])
+
+def _is_aggregate_candidate(value):
+    return parse_numeric_value(value) is not None
+
+def compute_column_summary(rows, column_name):
+    strategy = get_column_aggregation(column_name)
+    values = []
+    for row in iter_detail_rows(rows):
+        if not isinstance(row, dict):
+            continue
+        parsed = parse_numeric_value(row.get(column_name))
+        if parsed is not None:
+            values.append(parsed)
+
+    if strategy == "none":
+        return ""
+    if strategy == "count":
+        return len(values)
+    if not values:
+        return ""
+    if strategy == "avg":
+        return sum(values) / Decimal(len(values))
+    return sum(values)
+
+def build_summary_row(rows, columns, label="汇总"):
+    summary = {}
+    for idx, column in enumerate(columns or []):
+        if idx == 0:
+            summary[column] = label
+            continue
+        summary[column] = compute_column_summary(rows, column)
+    return mark_summary_row(summary)
+
+def append_or_replace_summary_row(rows, columns, label="汇总"):
+    detail_rows = list(iter_detail_rows(rows))
+    summary_row = build_summary_row(detail_rows, columns, label=label)
+    detail_rows.append(summary_row)
+    return detail_rows
+
@@
